 android/app/src/main/res/font/inter_bold.ttf  | Bin 0 -> 420428 bytes
 .../app/src/main/res/font/inter_medium.ttf    | Bin 0 -> 417300 bytes
 .../app/src/main/res/font/inter_regular.ttf   | Bin 0 -> 411640 bytes
 .../app/src/main/res/font/inter_semibold.ttf  | Bin 0 -> 419744 bytes
 6 files changed, 102 insertions(+), 3 deletions(-)
