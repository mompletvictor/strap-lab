+package com.noop.ingest
+
+import com.noop.analytics.LabBookProjection
+import com.noop.analytics.LabMarkerCategory
+import java.time.Instant
+import java.time.LocalDate
+import java.time.ZoneId
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertNull
+import org.junit.Test
+
+/**
+ * The Health Connect blood-pressure import maps one cuff reading to the Lab Book's
+ * systolic+diastolic row pair — the same shape the manual marker editor writes — via
+ * [HealthConnectImporter.bloodPressureRows]. This pins that contract: deterministic ids
+ * ("<key>-<epochSecond>-hc") so re-imports upsert instead of duplicating, the catalog's
+ * bp_systolic/bp_diastolic keys, mmHg unit, and values rounded to one place. No Health
+ * Connect client needed.
+ */
+class BloodPressureImportTest {
+
+    private val time: Instant = Instant.ofEpochSecond(1_752_672_000L) // 2025-07-16T13:20:00Z
+
+    @Test fun mapsOneReadingToSystolicAndDiastolicRows() {
+        val rows = HealthConnectImporter.bloodPressureRows(120.0, 80.0, time)
+        assertEquals(2, rows.size)
+        val (sys, dia) = rows
+
+        assertEquals(LabBookProjection.BP_SYSTOLIC_KEY, sys.markerKey)
+        assertEquals(LabBookProjection.BP_DIASTOLIC_KEY, dia.markerKey)
+        assertEquals(120.0, sys.value!!, 1e-9)
+        assertEquals(80.0, dia.value!!, 1e-9)
+        for (row in rows) {
+            assertEquals(LabMarkerCategory.BLOOD_PRESSURE.raw, row.category)
+            assertEquals("mmHg", row.unit)
+            assertEquals("health-connect", row.source)
+            assertEquals(time.epochSecond, row.takenAt)
+            assertEquals(LocalDate.ofInstant(time, ZoneId.systemDefault()).toString(), row.day)
+            assertNull(row.valueText)
+        }
+    }
+
+    @Test fun idsAreDeterministicSoReimportsUpsert() {
+        val first = HealthConnectImporter.bloodPressureRows(120.0, 80.0, time)
+        val second = HealthConnectImporter.bloodPressureRows(120.0, 80.0, time)
+        assertEquals("bp_systolic-${time.epochSecond}-hc", first[0].id)
+        assertEquals("bp_diastolic-${time.epochSecond}-hc", first[1].id)
+        assertEquals(first.map { it.id }, second.map { it.id })
+    }
+
+    @Test fun valuesRoundToOnePlaceLikeOtherHcMetrics() {
+        val rows = HealthConnectImporter.bloodPressureRows(120.4999, 79.9501, time)
+        assertEquals(120.5, rows[0].value!!, 1e-9)
+        assertEquals(80.0, rows[1].value!!, 1e-9)
+    }
+}
