+    /**
+     * Map one blood-pressure reading (mmHg) to the Lab Book's systolic+diastolic [LabMarkerRow]
+     * pair — the same shape the manual marker editor writes. Ids are deterministic
+     * ("<key>-<epochSecond>-hc") so a re-import upserts the same rows instead of duplicating them.
+     * Factored out (and internal) so the mapping can be unit-tested without a HealthConnectClient.
+     */
+    internal fun bloodPressureRows(
+        systolicMmHg: Double,
+        diastolicMmHg: Double,
+        time: Instant,
+    ): List<LabMarkerRow> {
+        val epoch = time.epochSecond
+        val day = LocalDate.ofInstant(time, ZoneId.systemDefault()).toString()
+        fun row(key: String, mmHg: Double) = LabMarkerRow(
+            id = "$key-$epoch-hc",
+            deviceId = WHOOP,
+            markerKey = key,
+            category = LabMarkerCategory.BLOOD_PRESSURE.raw,
+            day = day,
+            takenAt = epoch,
+            value = round1(mmHg),
+            valueText = null,
+            unit = "mmHg",
+            source = HC_DEVICE,
+            note = null,
+            referenceText = null,
+        )
+        return listOf(
+            row(LabBookProjection.BP_SYSTOLIC_KEY, systolicMmHg),
+            row(LabBookProjection.BP_DIASTOLIC_KEY, diastolicMmHg),
+        )
+    }
