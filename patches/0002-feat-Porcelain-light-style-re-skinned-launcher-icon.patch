 .../app/src/main/java/com/noop/ui/Theme.kt    |  4 +-
 .../res/drawable/ic_launcher_background.xml   |  4 +-
 .../res/drawable/ic_launcher_foreground.xml   |  6 +-
 6 files changed, 101 insertions(+), 7 deletions(-)
